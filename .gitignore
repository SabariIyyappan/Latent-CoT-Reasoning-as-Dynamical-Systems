# Python
model_env/
__pycache__/
*.pyc
*.pyo
.eggs/
*.egg-info/

# Per-experiment pinned virtualenvs (e.g. .venv-simcot311 for the literal
# SIM-CoT runs). Each experiment branch may have its own pinned env at the
# repo root; never commit it (3+ GB of wheels).
.venv*/
venv*/

# Model checkpoints (too large for git)
checkpoints/

# LatentTTS local clone (upstream source now lives in src/)
LatentTTS/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Experiment tracking (wandb-only; run logs under results/ ARE tracked)
wandb/

# Documentation: track .md/.txt (concept bucketing, review responses,
# verify-claims logs) but keep the reference PDFs (proposal / plan) local.
docs/

# Claude Code project instructions (local only)
CLAUDE.md
.claude/

# Prepared/cached datasets (e.g. data/gsm8k_for_literal/*.json). Each
# experiment re-prepares its own JSON dump; never commit the raw data.
data/

# NOTE: results/ tracks PLOTS ONLY (PNG/JPG/SVG/PDF) plus configs, manifests,
# and run logs. HDF5 latent-state caches and any other large numeric dumps
# are too big for git and are regenerated by the extract scripts.
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pt
*.pth


# Runtime logs from training/inference (large, regenerable)
logs/
dist/
